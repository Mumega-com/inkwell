# Inkwell environment reference.
# Copy to .env for local development. Use Cloudflare Pages/Workers secrets for production.

# Site identity
SITE_NAME="Inkwell Site"
SITE_DOMAIN=example.com
SITE_TAGLINE="Publish with agents, not busywork."
SITE_URL=https://example.com

# Public browser-visible SaaS API base for pages such as /connect.
# Leave empty for standalone sites.
PUBLIC_SOS_SAAS_URL=

# Worker/SaaS integration
SOS_SAAS_URL=
SOS_BUS_URL=
SOS_MIRROR_URL=
SOS_ECONOMY_URL=
SOS_MODE=standalone
NETWORK_API_URL=
NETWORK_TOKEN=

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
KV_NAMESPACE_ID=
R2_BUCKET=inkwell-media
INKWELL_WORKER_URL=https://your-worker.workers.dev
CF_PAGES_DEPLOY_HOOK=

# Publishing API
PUBLISH_TOKEN=sk-inkwell-publish-placeholder
INKWELL_MCP_TOKEN=sk-inkwell-mcp-placeholder

# Analytics. Leave empty to disable.
GOOGLE_ANALYTICS=
CLARITY=
HOTJAR=
TAG_MANAGER=
PLAUSIBLE=

# Payments
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_SEO=price_placeholder
STRIPE_PRICE_SEO_ADS=price_placeholder
STRIPE_PRICE_FULL=price_placeholder

# Messaging
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RESEND_API_KEY=
RESEND_FROM_EMAIL="Inkwell <hello@example.com>"
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Auth and contracts
AUTH_COOKIE_NAME=inkwell_session
AUTH_SESSION_TTL_SECONDS=86400
AUTH_CODE_TTL_SECONDS=600
AUTH_CODE_WEBHOOK_URL=
AUTH_CODE_WEBHOOK_TOKEN=
CONTRACT_AUTH_TOKEN=

# Search/analytics connectors
GSC_CREDENTIALS=
GSC_SITE_URL=https://example.com/
GA4_CREDENTIALS=
GA4_PROPERTY_ID=
