# ============================================================
# Inkwell Worker — Environment Variables Reference
# ============================================================
# This file documents all environment variables used by the
# Inkwell Worker (workers/inkwell-api).
#
# HOW TO USE:
#   Non-sensitive values → set in wrangler.toml under [vars]
#   Secrets → set via: npx wrangler secret put VAR_NAME
#
# Variables marked [REQUIRED] must be set before deploying.
# Variables marked [SECRET] must use `wrangler secret put`.
# Variables marked [OPTIONAL] have sensible defaults or are
# feature-specific — set only if you use that feature.
# ============================================================


# ── Site Identity ────────────────────────────────────────────

# [REQUIRED] Your deployed site URL (no trailing slash)
# Set in wrangler.toml [vars]
SITE_URL=https://example.com

# [OPTIONAL] Human-readable name shown in emails/messages
BUSINESS_NAME=Acme Corp

# [OPTIONAL] Contact phone shown in templates
BUSINESS_PHONE=1-800-555-0199

# [OPTIONAL] Contact email shown in templates
BUSINESS_EMAIL=info@example.com


# ── Publishing ───────────────────────────────────────────────

# [OPTIONAL][SECRET] Bearer token required to POST /api/publish
# Generate: openssl rand -hex 32
# Use with: Authorization: Bearer <token>
PUBLISH_TOKEN=sk-inkwell-publish-xxxxxxxxxxxxxxxx

# [OPTIONAL] Cloudflare Pages deploy hook URL
# Triggered after successful content publish
# Get from: Cloudflare Pages → Settings → Builds & Deployments → Deploy hooks
CF_PAGES_DEPLOY_HOOK=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/xxxxxxxx


# ── Authentication (passwordless code flow) ──────────────────

# [OPTIONAL] Cookie name for auth sessions (default: inkwell_session)
AUTH_COOKIE_NAME=inkwell_session

# [OPTIONAL] Session TTL in seconds (default: 86400 = 24h)
AUTH_SESSION_TTL_SECONDS=86400

# [OPTIONAL] Auth code TTL in seconds (default: 600 = 10min)
AUTH_CODE_TTL_SECONDS=600

# [OPTIONAL] Webhook URL to receive auth codes (email/SMS delivery)
AUTH_CODE_WEBHOOK_URL=https://your-delivery-service.com/webhook

# [OPTIONAL][SECRET] Bearer token for the auth code webhook
AUTH_CODE_WEBHOOK_TOKEN=your-webhook-token


# ── Stripe Payments ──────────────────────────────────────────
# Required if features.payments = true or features.commerce = true

# [REQUIRED for payments][SECRET] Stripe secret key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# [REQUIRED for payments][SECRET] Stripe webhook signing secret
# Get from: Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Stripe Price IDs for subscription tiers
# Create prices in Stripe Dashboard, paste IDs here
STRIPE_PRICE_SEO=price_xxxxxxxxxx
STRIPE_PRICE_SEO_ADS=price_xxxxxxxxxx
STRIPE_PRICE_FULL=price_xxxxxxxxxx


# ── Telegram ─────────────────────────────────────────────────
# Required if features.telegram = true

# [REQUIRED for telegram][SECRET] Bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...

# [OPTIONAL] Default Telegram chat ID for outbound notifications
# Get by messaging your bot and calling: GET /getUpdates
TELEGRAM_CHAT_ID=123456789


# ── Email (Resend) ───────────────────────────────────────────
# Required for contract confirmation emails

# [OPTIONAL][SECRET] Resend API key
# Get from: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# [OPTIONAL] Sender identity (requires verified domain in Resend)
# Format: "Display Name <address@yourdomain.com>"
RESEND_FROM_EMAIL=Your Business <contracts@example.com>


# ── SMS (Twilio) ─────────────────────────────────────────────
# Required for contract confirmation SMS

# [OPTIONAL][SECRET] Twilio Account SID
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [OPTIONAL][SECRET] Twilio Auth Token
TWILIO_AUTH_TOKEN=your_auth_token_here

# [OPTIONAL] Twilio phone number to send from (E.164 format)
TWILIO_FROM_NUMBER=+15550001234


# ── Analytics Flywheel ───────────────────────────────────────
# Required if features.flywheel = true

# [OPTIONAL][SECRET] Google Search Console OAuth credentials (JSON blob)
# Format: {"client_id":"...","client_secret":"...","refresh_token":"..."}
GSC_CREDENTIALS={"client_id":"...","client_secret":"...","refresh_token":"..."}

# [OPTIONAL] GSC property URL (must match exactly in GSC)
GSC_SITE_URL=https://example.com/

# [OPTIONAL][SECRET] Google Analytics 4 OAuth credentials (JSON blob)
# Format: {"client_id":"...","client_secret":"...","refresh_token":"..."}
GA4_CREDENTIALS={"client_id":"...","client_secret":"...","refresh_token":"..."}

# [OPTIONAL] GA4 property ID (numeric, from GA4 → Admin → Property Settings)
GA4_PROPERTY_ID=370995758


# ── MCP Server ───────────────────────────────────────────────

# [OPTIONAL][SECRET] Bearer token required by MCP clients
# Generate: openssl rand -hex 32
# Used in: Authorization: Bearer <token>
INKWELL_MCP_TOKEN=sk-inkwell-mcp-xxxxxxxxxxxxxxxx

# [OPTIONAL] Custom system prompt for the chat assistant
CHAT_SYSTEM_PROMPT=You are a helpful assistant for this website.


# ── Contracts ────────────────────────────────────────────────

# [OPTIONAL][SECRET] Bearer token for contract milestone update endpoint
CONTRACT_AUTH_TOKEN=your-contract-auth-token


# ── Agent Bus (Mumega SaaS — optional) ───────────────────────
# Set these only if connecting to a Mumega SaaS instance.
# Standalone deployments do NOT need these.

# [OPTIONAL] SOS bus SSE URL for forwarding chat messages to agents
# Example: https://mcp.mumega.com/sse/<your-token>
SOS_BUS_URL=

# [OPTIONAL] SaaS service URL for multi-tenant resolution
# Only needed for *.yourdomain.com wildcard routing
SOS_SAAS_URL=

# [OPTIONAL] Network API base URL for network tools (memory, tasks, marketplace)
NETWORK_API_URL=

# [OPTIONAL][SECRET] Bearer token for network API
NETWORK_TOKEN=

# [OPTIONAL] Agent bus recipient for daily flywheel reports (default: owner)
SOS_REPORT_RECIPIENT=owner


# ── Feature Routing ──────────────────────────────────────────

# [OPTIONAL] Comma-separated list of enabled route groups
# Leave empty to enable all routes.
# Example: "dashboard,leads,mcp" to run a minimal read-only instance
ENABLED_ROUTES=
