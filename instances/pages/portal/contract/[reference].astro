---
// Contract portal page — static page, contract data is fetched client-side by ContractPortal island.
// The [reference] segment is used only for URL routing; the actual reference is read from window.location.
export function getStaticPaths() {
  // We cannot pre-generate paths for runtime contract references.
  // Astro requires this export for dynamic routes in static mode, but we return a demo path —
  // the page is deployed once and handles all references client-side.
  return [
    { params: { reference: 'demo' } }
  ]
}

const title = 'Your Contract — Viamar Freight'
const description = 'Review and sign your Viamar auto export contract securely online.'
---

<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon.ico" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root[data-theme="dark"] {
      --ink-bg: #0d0d0d;
      --ink-surface: #161616;
      --ink-border: #2a2a2a;
      --ink-text: #f0f0f0;
      --ink-muted: #a0a0a0;
      --ink-dim: #606060;
      --ink-primary: #D4A017;
      --ink-secondary: #06B6D4;
      --ink-font-mono: 'Courier New', monospace;
    }

    body {
      background: var(--ink-bg);
      color: var(--ink-text);
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      line-height: 1.6;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .portal-header {
      border-bottom: 1px solid var(--ink-border);
      padding: 1.25rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: var(--ink-surface);
      flex-shrink: 0;
    }

    .portal-logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .portal-logo-text {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--ink-text);
      letter-spacing: -0.01em;
    }

    .portal-logo-sub {
      font-size: 0.72rem;
      color: var(--ink-muted);
    }

    .portal-badge {
      font-size: 0.72rem;
      font-weight: 600;
      padding: 0.25rem 0.6rem;
      border-radius: 4px;
      background: color-mix(in srgb, var(--ink-primary) 15%, transparent);
      border: 1px solid color-mix(in srgb, var(--ink-primary) 30%, transparent);
      color: var(--ink-primary);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .portal-main {
      max-width: 760px;
      width: 100%;
      margin: 0 auto;
      padding: 2.5rem 1.5rem 4rem;
      flex: 1;
    }

    .portal-page-header {
      margin-bottom: 2rem;
    }

    .portal-page-header h1 {
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--ink-text);
      margin-bottom: 0.4rem;
    }

    .portal-page-header p {
      font-size: 0.9rem;
      color: var(--ink-muted);
    }

    .portal-footer {
      border-top: 1px solid var(--ink-border);
      padding: 1.25rem 2rem;
      text-align: center;
      font-size: 0.75rem;
      color: var(--ink-dim);
      flex-shrink: 0;
    }

    @media (max-width: 600px) {
      .portal-header { padding: 1rem 1.25rem; }
      .portal-badge { display: none; }
    }
  </style>
</head>
<body>

  <header class="portal-header">
    <div class="portal-logo">
      <svg width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true">
        <rect width="36" height="36" rx="7" fill="#D4A017" fill-opacity="0.18"/>
        <path d="M7 26L13 12l5.5 9 4.5-6 6 11" stroke="#D4A017" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="29" cy="26" r="1.8" fill="#D4A017"/>
      </svg>
      <div>
        <div class="portal-logo-text">Viamar</div>
        <div class="portal-logo-sub">International Auto Shipping</div>
      </div>
    </div>
    <span class="portal-badge">Secure Contract Portal</span>
  </header>

  <main class="portal-main">
    <div class="portal-page-header">
      <h1>Your Export Contract</h1>
      <p>Review your shipment details, select insurance coverage, and sign electronically to proceed.</p>
    </div>

    <div id="contract-portal-mount"></div>
  </main>

  <footer class="portal-footer">
    Viamar International Shipping &nbsp;&mdash;&nbsp; CIFFA Member &nbsp;&mdash;&nbsp;
    All services subject to CIFFA Standard Trading Conditions
  </footer>

</body>
</html>

<script>
  // Mount the ContractPortal React island into the placeholder div.
  // This runs client-side so the reference can be read from window.location.
  import { createElement } from 'react'
  import { createRoot } from 'react-dom/client'
  import { ContractPortal } from '../../../components/ContractPortal'

  const mount = document.getElementById('contract-portal-mount')
  if (mount) {
    const root = createRoot(mount)
    root.render(createElement(ContractPortal, null))
  }
</script>
