---
// Starter index page — generated by `sos init`.
// Placeholders ({{LABEL}}, {{TAGLINE}}, {{SLUG}}) are interpolated at init time.
import BaseLayout from '../../src/layouts/Base.astro'
---

<BaseLayout title="{{LABEL}}" description="{{TAGLINE}}">
  <main class="hero-wrap">
    <section class="hero">
      <h1 class="hero-name">{{LABEL}}</h1>
      <p class="hero-tagline">{{TAGLINE}}</p>
      <a href="/contact" class="hero-cta">Get started</a>
    </section>
  </main>
</BaseLayout>

<style>
  .hero-wrap {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
  }

  .hero {
    max-width: 640px;
    text-align: center;
  }

  .hero-name {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: var(--ink-text);
    margin: 0 0 1rem;
    line-height: 1.15;
  }

  .hero-tagline {
    font-size: 1.15rem;
    color: var(--ink-muted);
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .hero-cta {
    display: inline-block;
    background: var(--ink-primary);
    color: #000;
    font-weight: 700;
    padding: 0.875rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .hero-cta:hover {
    opacity: 0.85;
  }
</style>
