---
interface DataPoint {
  ts: string
  value: number
}

interface Props {
  title: string
  points: DataPoint[]
}

const { title, points } = Astro.props

// Build a simple SVG polyline from the data points
const W = 220
const H = 60
const PADDING = 4

let path = ''
if (points.length > 1) {
  const values = points.map(p => p.value)
  const min = Math.min(...values)
  const max = Math.max(...values)
  const range = max - min || 1  // avoid divide-by-zero when all values equal

  const coords = points.map((p, i) => {
    const x = PADDING + (i / (points.length - 1)) * (W - PADDING * 2)
    const y = PADDING + (1 - (p.value - min) / range) * (H - PADDING * 2)
    return `${x.toFixed(1)},${y.toFixed(1)}`
  })

  path = coords.join(' ')
}

const latest = points.length > 0 ? points[points.length - 1]?.value : null
---

<div class="glass-tile glass-tile--sparkline">
  <div class="glass-sparkline-header">
    <span class="glass-tile-title">{title}</span>
    {latest !== null && <span class="glass-sparkline-latest">{latest.toLocaleString()}</span>}
  </div>
  {points.length > 1 ? (
    <svg
      width={W}
      height={H}
      viewBox={`0 0 ${W} ${H}`}
      aria-hidden="true"
      class="glass-sparkline-svg"
    >
      <polyline
        points={path}
        fill="none"
        stroke="var(--ink-primary)"
        stroke-width="2"
        stroke-linejoin="round"
        stroke-linecap="round"
      />
    </svg>
  ) : (
    <div class="glass-sparkline-empty">No data</div>
  )}
</div>

<style>
  .glass-tile {
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .glass-sparkline-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .glass-tile-title {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-muted);
  }

  .glass-sparkline-latest {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--ink-text);
    font-variant-numeric: tabular-nums;
  }

  .glass-sparkline-svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .glass-sparkline-empty {
    font-size: 0.85rem;
    color: var(--ink-muted);
    font-style: italic;
  }
</style>
