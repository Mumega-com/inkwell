---
import Base from '../layouts/Base.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import { MovingQuoteForm } from '../components/MovingQuoteForm'
import { config } from '../lib/config'

const palletTable = [
  { pallets: '0.5', cubicFeet: '50–100', moveType: 'Small Move', typicalUse: 'Few boxes, mattress, chairs' },
  { pallets: '1', cubicFeet: '100–150', moveType: 'Studio / Small 1BR', typicalUse: 'Studio apartment or small 1-bedroom' },
  { pallets: '2', cubicFeet: '150–300', moveType: 'Medium Move', typicalUse: 'Typical 1-bedroom apartment' },
  { pallets: '3', cubicFeet: '300–450', moveType: 'Large Move', typicalUse: 'Larger 1-bedroom or small 2-bedroom' },
  { pallets: '4', cubicFeet: '450–600', moveType: 'Large 2BR / Townhouse', typicalUse: 'Larger apartment or townhouse' },
  { pallets: '6+', cubicFeet: '800+', moveType: 'Full House', typicalUse: 'Full household move' },
]

const moveSizes = [
  {
    title: 'Small Move',
    range: '50–100 cu ft',
    pallets: '~0.5 pallet',
    desc: 'Few boxes, mattress, chairs',
    icon: '📦',
  },
  {
    title: 'Medium Move',
    range: '150–300 cu ft',
    pallets: '~1–2 pallets',
    desc: 'Typical 1-bedroom apartment',
    icon: '🛋️',
  },
  {
    title: 'Large Move',
    range: '350–600 cu ft',
    pallets: '~2–3 pallets',
    desc: 'Larger apartment, townhouse',
    icon: '🏠',
  },
  {
    title: 'Full House',
    range: '800+ cu ft',
    pallets: '~4+ pallets',
    desc: 'Full household moves',
    icon: '🏡',
  },
]

const whyCards = [
  {
    icon: '→',
    title: 'Clearer Quoting',
    desc: 'We quote by cubic feet and pallets — not vague estimates. You know what you\'re paying and why.',
  },
  {
    icon: '↗',
    title: 'Better Transit Expectations',
    desc: 'Scheduled 7–10 day LTL service means you get a realistic window, not a surprise call at 6am.',
  },
  {
    icon: '▣',
    title: 'Real Warehouse Infrastructure',
    desc: 'Your goods move through our licensed warehouse in Vaughan, ON — not a random broker\'s garage.',
  },
]
---

<Base
  title="Domestic Moving Across Canada — Viamar"
  description="Fast, reliable domestic moving from Toronto to Alberta, British Columbia, and beyond. Scheduled LTL and dedicated truck service. Request a quote today."
>
  <Header />

  <main class="moving-page">

    {/* ── Hero ── */}
    <section class="mv-hero">
      <div class="mv-hero-inner">
        <span class="mv-eyebrow">Domestic Moving</span>
        <h1 class="mv-hero-title">
          Fast, reliable moving across Canada —<br>
          <span class="mv-hero-accent">backed by real logistics experience.</span>
        </h1>
        <p class="mv-hero-sub">
          From Toronto to Alberta, British Columbia, and beyond.<br>
          7–10 day scheduled LTL transit.
        </p>
        <a href="#quote-form" class="mv-cta-btn">Request a Quote</a>
      </div>
      <div class="mv-hero-badge">
        <span class="mv-badge-text">Est. 1982</span>
        <span class="mv-badge-sub">CIFFA Member</span>
      </div>
    </section>

    {/* ── How We Quote ── */}
    <section class="mv-section">
      <div class="mv-section-inner">
        <h2 class="mv-section-title">How We Quote</h2>
        <p class="mv-section-sub">
          Pricing is based on how much space your move actually takes — not a guessed weight or a mystery formula.
        </p>
        <div class="mv-quote-grid">
          <div class="mv-quote-card">
            <div class="mv-quote-icon">◱</div>
            <h3>Smaller Shipments</h3>
            <p class="mv-quote-type">Shared / LTL Service</p>
            <ul class="mv-quote-list">
              <li>Quoted by cubic feet or pallets</li>
              <li>Standard platform: 7'×4' (48"×84")</li>
              <li>Shared space with other cargo</li>
              <li>7–10 day scheduled transit</li>
            </ul>
            <p class="mv-quote-note">Best for: studio apartments, partial moves, smaller loads</p>
          </div>
          <div class="mv-quote-card">
            <div class="mv-quote-icon">▣</div>
            <h3>Larger Shipments</h3>
            <p class="mv-quote-type">Dedicated Truck Service</p>
            <ul class="mv-quote-list">
              <li>Dedicated vehicle for your move</li>
              <li>Direct service, no co-loading</li>
              <li>Full household loads</li>
              <li>Flexible scheduling</li>
            </ul>
            <p class="mv-quote-note">Best for: full apartments, townhouses, house moves</p>
          </div>
        </div>
      </div>
    </section>

    {/* ── Move Sizes ── */}
    <section class="mv-section mv-section--alt">
      <div class="mv-section-inner">
        <h2 class="mv-section-title">Move Sizes</h2>
        <p class="mv-section-sub">
          Not sure how much space you need? Use these as a guide.
        </p>
        <div class="mv-sizes-grid">
          {moveSizes.map((size) => (
            <div class="mv-size-card">
              <div class="mv-size-icon">{size.icon}</div>
              <h3 class="mv-size-title">{size.title}</h3>
              <div class="mv-size-range">{size.range}</div>
              <div class="mv-size-pallets">{size.pallets}</div>
              <p class="mv-size-desc">{size.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Pallet Reference Table ── */}
    <section class="mv-section">
      <div class="mv-section-inner">
        <h2 class="mv-section-title">Pallet Reference</h2>
        <p class="mv-section-sub">
          All LTL pricing is based on standard 48"×40" pallets. Here's how your move converts.
        </p>
        <div class="mv-table-wrap">
          <table class="mv-table">
            <thead>
              <tr>
                <th>Pallets</th>
                <th>Cubic Feet</th>
                <th>Move Type</th>
                <th>Typical Use</th>
              </tr>
            </thead>
            <tbody>
              {palletTable.map((row) => (
                <tr>
                  <td><strong>{row.pallets}</strong></td>
                  <td>{row.cubicFeet}</td>
                  <td>{row.moveType}</td>
                  <td class="mv-table-muted">{row.typicalUse}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="mv-table-note">
          1 standard pallet = 48"×40"×48" tall ≈ 150 cubic feet. Stacking depends on cargo type.
        </p>
      </div>
    </section>

    {/* ── Why Viamar ── */}
    <section class="mv-section mv-section--alt">
      <div class="mv-section-inner">
        <h2 class="mv-section-title">Why VIAMAR</h2>
        <p class="mv-section-sub">
          We've been moving cars internationally since 1982. Now we're bringing that same infrastructure to domestic moves.
        </p>
        <div class="mv-why-grid">
          {whyCards.map((card) => (
            <div class="mv-why-card">
              <div class="mv-why-icon">{card.icon}</div>
              <h3 class="mv-why-title">{card.title}</h3>
              <p class="mv-why-desc">{card.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ── Quote Form ── */}
    <section class="mv-section" id="quote-form">
      <div class="mv-section-inner mv-section-inner--narrow">
        <h2 class="mv-section-title">Request a Quote</h2>
        <p class="mv-section-sub">
          Tell us about your move and we'll get back to you within 1 business day.
        </p>
        <MovingQuoteForm client:visible />
      </div>
    </section>

    {/* ── Bottom CTA ── */}
    <section class="mv-contact-bar">
      <div class="mv-contact-inner">
        <p class="mv-contact-text">Prefer to talk? We're here.</p>
        <div class="mv-contact-links">
          <a href="tel:18002777570" class="mv-contact-link">1-800-277-7570</a>
          <span class="mv-contact-sep">·</span>
          <a href="mailto:info@viamar.ca" class="mv-contact-link">info@viamar.ca</a>
        </div>
        <p class="mv-contact-sub">
          Viamar Scilla Transport International Inc. — 4000 Steeles Ave W, Unit 9, Vaughan, ON L4L 4V9
        </p>
      </div>
    </section>

  </main>

  <Footer />
</Base>

<style>
  /* ── Page Layout ── */
  .moving-page {
    background: var(--ink-bg);
    color: var(--ink-text);
  }

  /* ── Hero ── */
  .mv-hero {
    position: relative;
    padding: 5rem 1.5rem 4rem;
    background: linear-gradient(160deg, var(--ink-bg) 0%, color-mix(in srgb, var(--ink-primary) 6%, var(--ink-bg)) 100%);
    border-bottom: 1px solid var(--ink-border);
    overflow: hidden;
  }

  .mv-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 70% 50%, color-mix(in srgb, var(--ink-primary) 8%, transparent), transparent 60%);
    pointer-events: none;
  }

  .mv-hero-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }

  .mv-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-primary);
    background: color-mix(in srgb, var(--ink-primary) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--ink-primary) 25%, transparent);
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }

  .mv-hero-title {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.2;
    color: var(--ink-text);
    margin: 0 0 1.25rem;
  }

  .mv-hero-accent {
    color: var(--ink-primary);
  }

  .mv-hero-sub {
    font-size: 1.1rem;
    color: var(--ink-muted);
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .mv-cta-btn {
    display: inline-block;
    background: var(--ink-primary);
    color: #000;
    font-weight: 700;
    font-size: 1rem;
    padding: 0.875rem 2rem;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .mv-cta-btn:hover {
    opacity: 0.88;
  }

  .mv-hero-badge {
    position: absolute;
    top: 2rem;
    right: 2rem;
    text-align: center;
    background: color-mix(in srgb, var(--ink-surface) 80%, transparent);
    border: 1px solid var(--ink-border);
    border-radius: 10px;
    padding: 0.75rem 1rem;
    display: none;
  }

  @media (min-width: 768px) {
    .mv-hero-badge { display: block; }
  }

  .mv-badge-text {
    display: block;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--ink-primary);
  }

  .mv-badge-sub {
    display: block;
    font-size: 0.7rem;
    color: var(--ink-dim);
    margin-top: 0.2rem;
  }

  /* ── Sections ── */
  .mv-section {
    padding: 4rem 1.5rem;
  }

  .mv-section--alt {
    background: color-mix(in srgb, var(--ink-surface) 50%, var(--ink-bg));
  }

  .mv-section-inner {
    max-width: 960px;
    margin: 0 auto;
  }

  .mv-section-inner--narrow {
    max-width: 680px;
  }

  .mv-section-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--ink-text);
    margin: 0 0 0.75rem;
    text-align: center;
  }

  .mv-section-sub {
    font-size: 1rem;
    color: var(--ink-muted);
    text-align: center;
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  /* ── How We Quote ── */
  .mv-quote-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .mv-quote-grid { grid-template-columns: 1fr 1fr; }
  }

  .mv-quote-card {
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: 12px;
    padding: 2rem;
  }

  .mv-quote-icon {
    font-size: 1.75rem;
    color: var(--ink-primary);
    margin-bottom: 1rem;
    line-height: 1;
  }

  .mv-quote-card h3 {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--ink-text);
    margin: 0 0 0.3rem;
  }

  .mv-quote-type {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ink-primary);
    margin: 0 0 1rem;
  }

  .mv-quote-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .mv-quote-list li {
    font-size: 0.9rem;
    color: var(--ink-muted);
    padding-left: 1.2rem;
    position: relative;
  }

  .mv-quote-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--ink-primary);
    font-size: 0.75rem;
    top: 0.1em;
  }

  .mv-quote-note {
    font-size: 0.8rem;
    color: var(--ink-dim);
    margin: 0;
    padding-top: 1rem;
    border-top: 1px solid var(--ink-border);
  }

  /* ── Move Sizes ── */
  .mv-sizes-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .mv-sizes-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .mv-size-card {
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: 12px;
    padding: 1.5rem 1rem;
    text-align: center;
    transition: border-color 0.15s;
  }

  .mv-size-card:hover {
    border-color: var(--ink-primary);
  }

  .mv-size-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .mv-size-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink-text);
    margin: 0 0 0.3rem;
  }

  .mv-size-range {
    font-size: 0.9rem;
    color: var(--ink-primary);
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .mv-size-pallets {
    font-size: 0.75rem;
    color: var(--ink-dim);
    margin-bottom: 0.5rem;
  }

  .mv-size-desc {
    font-size: 0.8rem;
    color: var(--ink-muted);
    margin: 0;
    line-height: 1.4;
  }

  /* ── Table ── */
  .mv-table-wrap {
    overflow-x: auto;
    border-radius: 10px;
    border: 1px solid var(--ink-border);
  }

  .mv-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .mv-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-dim);
    background: color-mix(in srgb, var(--ink-surface) 60%, var(--ink-bg));
    border-bottom: 1px solid var(--ink-border);
  }

  .mv-table td {
    padding: 0.75rem 1rem;
    color: var(--ink-text);
    border-bottom: 1px solid color-mix(in srgb, var(--ink-border) 50%, transparent);
    vertical-align: middle;
  }

  .mv-table tr:last-child td {
    border-bottom: none;
  }

  .mv-table tr:hover td {
    background: color-mix(in srgb, var(--ink-surface) 40%, transparent);
  }

  .mv-table-muted {
    color: var(--ink-muted) !important;
  }

  .mv-table-note {
    font-size: 0.8rem;
    color: var(--ink-dim);
    margin: 1rem 0 0;
    text-align: center;
  }

  /* ── Why VIAMAR ── */
  .mv-why-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .mv-why-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .mv-why-card {
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: 12px;
    padding: 2rem 1.5rem;
  }

  .mv-why-icon {
    font-size: 1.5rem;
    color: var(--ink-primary);
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .mv-why-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--ink-text);
    margin: 0 0 0.6rem;
  }

  .mv-why-desc {
    font-size: 0.9rem;
    color: var(--ink-muted);
    margin: 0;
    line-height: 1.6;
  }

  /* ── Contact Bar ── */
  .mv-contact-bar {
    background: color-mix(in srgb, var(--ink-primary) 8%, var(--ink-bg));
    border-top: 1px solid color-mix(in srgb, var(--ink-primary) 20%, transparent);
    padding: 2.5rem 1.5rem;
    text-align: center;
  }

  .mv-contact-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .mv-contact-text {
    font-size: 1rem;
    font-weight: 600;
    color: var(--ink-text);
    margin: 0 0 0.6rem;
  }

  .mv-contact-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .mv-contact-link {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink-primary);
    text-decoration: none;
  }

  .mv-contact-link:hover {
    text-decoration: underline;
  }

  .mv-contact-sep {
    color: var(--ink-dim);
  }

  .mv-contact-sub {
    font-size: 0.78rem;
    color: var(--ink-dim);
    margin: 0;
  }
</style>

{/* ── Quote Form Styles (scoped to island) ── */}
<style is:global>
  .mq-form {
    background: var(--ink-surface);
    border: 1px solid var(--ink-border);
    border-radius: 14px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .mq-grid {
    display: grid;
    gap: 1rem;
  }

  .mq-grid-2 {
    grid-template-columns: 1fr;
  }

  @media (min-width: 480px) {
    .mq-grid-2 { grid-template-columns: 1fr 1fr; }
  }

  .mq-field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .mq-field label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .mq-field input,
  .mq-field textarea {
    background: var(--ink-bg);
    border: 1px solid var(--ink-border);
    border-radius: 8px;
    padding: 0.7rem 0.875rem;
    font-size: 0.95rem;
    color: var(--ink-text);
    font-family: inherit;
    width: 100%;
    box-sizing: border-box;
    transition: border-color 0.15s;
  }

  .mq-field input:focus,
  .mq-field textarea:focus {
    outline: none;
    border-color: var(--ink-primary);
  }

  .mq-field textarea {
    resize: vertical;
    min-height: 80px;
  }

  .mq-hint {
    font-size: 0.75rem;
    color: var(--ink-dim);
  }

  /* Radio Cards */
  .mq-radio-group {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 480px) {
    .mq-radio-group { grid-template-columns: 1fr 1fr; }
  }

  .mq-radio-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem;
    border: 1px solid var(--ink-border);
    border-radius: 10px;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    background: var(--ink-bg);
  }

  .mq-radio-card input[type="radio"] {
    display: none;
  }

  .mq-radio-card--active {
    border-color: var(--ink-primary);
    background: color-mix(in srgb, var(--ink-primary) 8%, var(--ink-bg));
  }

  .mq-radio-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink-text);
  }

  .mq-radio-sub {
    font-size: 0.78rem;
    color: var(--ink-muted);
    line-height: 1.4;
  }

  /* Size Cards */
  .mq-size-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
  }

  @media (min-width: 400px) {
    .mq-size-grid { grid-template-columns: repeat(4, 1fr); }
  }

  .mq-size-card {
    background: var(--ink-bg);
    border: 1px solid var(--ink-border);
    border-radius: 8px;
    padding: 0.75rem 0.5rem;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    transition: border-color 0.15s, background 0.15s;
    font-family: inherit;
    text-align: center;
  }

  .mq-size-card:hover {
    border-color: color-mix(in srgb, var(--ink-primary) 50%, var(--ink-border));
  }

  .mq-size-card--active {
    border-color: var(--ink-primary);
    background: color-mix(in srgb, var(--ink-primary) 8%, var(--ink-bg));
  }

  .mq-size-name {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--ink-text);
  }

  .mq-size-pallets {
    font-size: 0.7rem;
    color: var(--ink-dim);
  }

  /* Submit */
  .mq-submit {
    background: var(--ink-primary);
    color: #000;
    font-weight: 700;
    font-size: 1rem;
    padding: 0.875rem;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.15s;
    font-family: inherit;
    width: 100%;
  }

  .mq-submit:hover:not(:disabled) {
    opacity: 0.88;
  }

  .mq-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .mq-error {
    color: #ef4444;
    font-size: 0.875rem;
    margin: 0;
    padding: 0.75rem 1rem;
