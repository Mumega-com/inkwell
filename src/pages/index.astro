---
import Base from '../layouts/Base.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import { NetworkHero } from '../components/visualization/NetworkHero'
import { OrganismAnimation } from '../components/visualization/OrganismAnimation'
import { getCollection } from 'astro:content'
import { config } from '../lib/config'

const allPosts = await getCollection('blog', (p) => p.data.status === 'published')
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()).slice(0, 4)

function timeAgo(date: Date): string {
  const diff = Date.now() - date.getTime()
  const days = Math.floor(diff / 86400000)
  if (days === 0) return 'today'
  if (days === 1) return 'yesterday'
  if (days < 7) return `${days}d ago`
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })
}

const squads = [
  { name: 'Content', desc: 'Blog posts, landing pages, wikis, auto-publishing', agents: 'Writer, Editor', icon: '>' },
  { name: 'SEO', desc: 'Audits, meta tags, geo pages, scale content', agents: 'Analyst, Builder', icon: '^' },
  { name: 'CRM', desc: 'Contacts, pipeline, deals, outreach sequences', agents: 'Sales, Outreach', icon: '◇' },
  { name: 'Agency', desc: 'Client onboarding, dashboards, reports', agents: 'Manager, Ops', icon: '◆' },
  { name: 'Growth', desc: 'Analytics, funnels, feedback, churn signals', agents: 'Metrics, Insight', icon: '@' },
  { name: 'Automation', desc: 'Workflows, social posting, media pipeline', agents: 'Workflow, Media', icon: '#' },
]
---

<Base title={`${config.name} — Tesla for your Business`} description="The destination-driven AI platform. You provide the destination and guidelines — we implement automated performance loops to drive your business forward.">
  <Header />

  <main>

    {/* ── Hero ── */}
    <section class="hero">
      <div class="hero-content">
        <span class="hero-eyebrow">The Destination-Driven Business Platform</span>
        <h1 class="hero-title">Tesla for Business</h1>
        <p class="hero-tagline">Set your destination. Our AI squads build the documentation, implement the performance loops, and automate your growth on autopilot.</p>
        <div class="hero-cta-row">
          <a href="/onboarding" class="hero-cta-primary">Set Your Destination &rarr;</a>
          <a href="/vision" class="hero-cta-secondary">The Vision</a>
        </div>
        <p class="hero-compat">41 MCP tools &middot; Agency management &middot; CRM &middot; SEO &middot; Content</p>
      </div>
    </section>

    {/* ── Organism Animation ── */}
    <section class="anim-section">
      <div class="anim-label-bar">
        <span class="anim-label">ORGANISM RUNTIME</span>
        <span class="anim-sub">How Mumega operates a customer end-to-end</span>
      </div>
      <div class="anim-stage">
        <OrganismAnimation client:visible height="100%" />
      </div>
    </section>

    {/* ── Kernel Animation ── */}
    <section class="anim-section">
      <div class="anim-label">
        <span class="anim-tag">LIVE DEMO</span>
        <span class="anim-caption">Watch the kernel boot, load plugins, bind ports, route requests, fan out events, and hot-swap an adapter — 48 seconds, 7 scenes.</span>
      </div>
      <div class="anim-stage">
        <KernelAnimation client:visible height="100%" />
      </div>
      <div class="anim-legend">
        <span class="legend-dot orange"></span> surface plugins &nbsp;
        <span class="legend-dot cyan"></span> service plugins &nbsp;
        <span class="legend-dot green"></span> AI plugins &nbsp;·&nbsp;
        space to pause · ←→ seek · 0 reset
      </div>
    </section>

    {/* ── Architecture strip ── */}
    <section class="arch-strip">
      <div class="arch-inner">
        <div class="arch-block">
          <div class="arch-block-label">KERNEL</div>
          <div class="arch-block-n">~430 LOC</div>
          <div class="arch-block-desc">Contracts only — types, plugin loader, adapter registry, RBAC, theme. Zero business logic.</div>
        </div>
        <div class="arch-arrow">→</div>
        <div class="arch-block">
          <div class="arch-block-label">24 PLUGINS</div>
          <div class="arch-block-n">self-contained</div>
          <div class="arch-block-desc">Each plugin owns routes, widgets, MCP tools, and migrations. No cross-plugin imports.</div>
        </div>
        <div class="arch-arrow">→</div>
        <div class="arch-block">
          <div class="arch-block-label">16 PORTS</div>
          <div class="arch-block-n">hexagonal</div>
          <div class="arch-block-desc">Every infra concern is a swappable adapter. Cloudflare → Postgres in one config line.</div>
        </div>
        <div class="arch-arrow">→</div>
        <div class="arch-block">
          <div class="arch-block-label">41 MCP TOOLS</div>
          <div class="arch-block-n">RBAC-gated</div>
          <div class="arch-block-desc">Claude calls typed tools to publish, query CRM, run SEO audits, and onboard clients — no custom code.</div>
        </div>
      </div>
    </section>

    {/* ── Plugins ── */}
    <section class="section">
      <div class="section-inner">
        <div class="section-header">
          <div>
            <h2 class="section-title">Agent Squads</h2>
            <p class="section-desc">Specialized teams that operate your business around the clock.</p>
          </div>
        </div>
        <p class="plugin-note">
          Enabled by listing in <code>config.plugins[]</code>. Not in the list → doesn't load. Period.
        </p>
      </div>
    </section>

    {/* ── Ports ── */}
    <section class="section alt">
      <div class="section-inner">
        <div class="section-header">
          <div>
            <h2 class="section-title">What ships with Mumega</h2>
            <p class="section-desc">Everything your business needs — built in, not bolted on.</p>
          </div>
        </div>
        <div class="ports-grid">
          {ports.map(p => (
            <div class="port-card">
              <div class="port-name">{p.name}</div>
              <div class="port-swap">{p.swap}</div>
            </div>
          ))}
        </div>
        <div class="port-example">
          <pre><code>{`// inkwell.config.ts
adapters: {
  storage:  "cloudflare.d1",   // → swap to "postgres" with zero plugin changes
  media:    "cloudflare.r2",
  session:  "cloudflare.kv",
  agent:    "anthropic.sonnet",
}`}</code></pre>
        </div>
      </div>
    </section>

    {/* ── Products ── */}
    {products.length > 0 && (
      <section class="section">
        <div class="section-inner">
          <div class="section-header">
            <div>
              <h2 class="section-title">Products</h2>
              <p class="section-desc">Turnkey solutions built on the Mumega platform.</p>
            </div>
            <a href="/products" class="section-link">All products &rarr;</a>
          </div>
          <div class="products-grid">
            {products.map((p) => (
              <a href={`/products/${p.id}`} class="product-card">
                <div class="product-top">
                  {p.data.marketplace && <span class="product-market">{p.data.marketplace}</span>}
                  {p.data.price && <span class="product-price">{p.data.price}</span>}
                </div>
                <h3 class="product-title">{p.data.title}</h3>
                <p class="product-desc">{p.data.description}</p>
                <ul class="product-feats">
                  {p.data.features.slice(0, 3).map((f) => <li>{f}</li>)}
                </ul>
              </a>
            ))}
          </div>
        </div>
        <div class="mcp-groups">
          {mcpTools.map(g => (
            <div class="mcp-group">
              <div class="mcp-group-label">{g.group}</div>
              <div class="mcp-tools">
                {g.tools.map(t => <code class="mcp-tool">{t}</code>)}
              </div>
            </div>
          ))}
        </div>
        <div class="mcp-note">
          Connect via <code>npx wrangler deploy</code> + set <code>NETWORK_TOKEN</code>.
          Claude calls <code>GET /api/mcp</code> — the kernel routes, RBAC checks, plugin responds.
        </div>
      </div>
    </section>

    {/* ── Fork guide ── */}
    <section class="section alt">
      <div class="section-inner">
        <div class="section-header">
          <div>
            <h2 class="section-title">The Team</h2>
            <p class="section-desc">{team.length} humans and AI agents building Mumega.</p>
          </div>
        </div>
        <div class="steps">
          <div class="step">
            <div class="step-n">01</div>
            <div class="step-body">
              <div class="step-title">Fork the repo</div>
              <div class="step-desc">One repo per customer. No subdomains, no multi-tenant shared infra unless you want it.</div>
            </div>
          </div>
          <div class="step">
            <div class="step-n">02</div>
            <div class="step-body">
              <div class="step-title">Edit <code>inkwell.config.ts</code></div>
              <div class="step-desc">Name, domain, theme, plugins, adapters — every customer config lives in one file.</div>
            </div>
          </div>
          <div class="step">
            <div class="step-n">03</div>
            <div class="step-body">
              <div class="step-title">Deploy to Cloudflare</div>
              <div class="step-desc"><code>npx wrangler deploy</code> — the Worker registers plugins, mounts routes, collects MCP tools. Live in seconds.</div>
            </div>
          </div>
          <div class="step">
            <div class="step-n">04</div>
            <div class="step-body">
              <div class="step-title">Connect Claude</div>
              <div class="step-desc">Point Claude at <code>/api/mcp</code>. It discovers 41 tools. Your customer's stack is now agent-operated.</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ── Latest posts ── */}
    {posts.length > 0 && (
      <section class="section">
        <div class="section-inner">
          <div class="section-header">
            <div>
              <h2 class="section-title">Build journal</h2>
              <p class="section-desc">What's shipping, what changed, what broke.</p>
            </div>
            <a href="/blog" class="section-link">All posts →</a>
          </div>
          <div class="feed">
            {posts.map((post) => (
              <a href={`/blog/${post.id}`} class="feed-item">
                <span class="feed-date">{timeAgo(new Date(post.data.date))}</span>
                <span class="feed-author">{post.data.author}</span>
                <span class="feed-title">{post.data.title}</span>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {/* ── Footer nav ── */}
    <section class="lore">
      <div class="lore-inner">
        <a href="/docs" class="lore-link">Documentation →</a>
        <a href="/vision" class="lore-link">Vision →</a>
        <a href="/about" class="lore-link">About →</a>
        <a href="/explore" class="lore-link">Knowledge graph →</a>
        <a href="/dashboard" class="lore-link">Dashboard →</a>
      </div>
    </section>

  </main>

  <Footer />
</Base>

<style>
  main { padding-top: 3.5rem; }

  /* ── Organism Animation ── */
  .anim-section {
    margin: 0 auto var(--space-3xl);
    max-width: var(--page-width);
    padding: 0 var(--space-lg);
  }
  .anim-label-bar {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-md);
    background: rgba(212,160,23,0.06);
    border: 1px solid rgba(212,160,23,0.18);
    border-bottom: none;
    font-family: 'JetBrains Mono', monospace;
  }
  .anim-label {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    color: var(--ink-primary);
  }
  .anim-sub {
    font-size: 0.75rem;
    color: var(--ink-muted);
  }
  .anim-stage {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #060810;
    border: 1px solid rgba(212,160,23,0.18);
  }

  /* ── Hero ── */
  .hero {
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    border-bottom: 1px solid var(--ink-border);
  }
  .hero-eyebrow {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-primary);
    font-weight: 600;
    display: block;
    margin-bottom: 0.75rem;
  }
  .hero-title {
    font-family: var(--ink-font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    color: var(--ink-text);
    letter-spacing: -0.04em;
    margin: 0 0 1rem;
  }
  .hero-tagline {
    font-size: 1.125rem;
    color: var(--ink-muted);
    max-width: 540px;
    margin: 0 auto 1.75rem;
    line-height: 1.5;
  }
  .hero-cta-row {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }
  .hero-cta-primary {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: var(--ink-primary);
    color: var(--ink-bg);
    font-family: var(--ink-font-display);
    font-weight: 700;
    font-size: 0.9375rem;
    border-radius: var(--ink-radius);
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .hero-cta-primary:hover { opacity: 0.85; }
  .hero-cta-secondary {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: transparent;
    color: var(--ink-text);
    font-family: var(--ink-font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: var(--ink-radius);
    border: 1px solid var(--ink-border);
    text-decoration: none;
    transition: border-color 0.15s;
    backdrop-filter: blur(4px);
  }
  .hero-cta-secondary:hover { border-color: var(--ink-primary); }
  .hero-compat {
    font-family: var(--ink-font-mono);
    font-size: 0.6875rem;
    color: var(--ink-dim);
    margin: 0;
  }
  .hero-two {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 680px;
    margin: 0 auto;
  }
  .hero-card {
    padding: 1.5rem;
    background: color-mix(in srgb, var(--ink-surface) 80%, transparent);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    backdrop-filter: blur(8px);
    text-align: left;
  }
  .hero-label {
    font-family: var(--ink-font-mono);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ink-primary);
    font-weight: 600;
  }
  .hero-pitch {
    font-family: var(--ink-font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--ink-text);
    margin: 0.5rem 0 0.375rem;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }
  .hero-sub {
    font-size: 1.0625rem;
    color: var(--ink-muted);
    line-height: 1.65;
    margin: 0 0 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-sub code {
    font-family: var(--ink-font-mono);
    font-size: 0.875em;
    color: var(--ink-primary);
    background: color-mix(in srgb, var(--ink-primary) 12%, transparent);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  .hero-actions {
    display: flex; justify-content: center; gap: 0.75rem; margin-bottom: 2.5rem;
  }
  .btn-primary {
    font-family: var(--ink-font-display);
    font-weight: 700; font-size: 0.9375rem;
    padding: 0.625rem 1.5rem;
    background: var(--ink-primary); color: #000;
    border-radius: var(--ink-radius);
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn-primary:hover { opacity: 0.88; }
  .btn-secondary {
    font-family: var(--ink-font-display);
    font-weight: 600; font-size: 0.9375rem;
    padding: 0.625rem 1.5rem;
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
    color: var(--ink-text);
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .btn-secondary:hover { border-color: var(--ink-primary); }

  .hero-stats {
    display: flex; justify-content: center; align-items: center; gap: 1.25rem;
  }
  .stat { display: flex; flex-direction: column; align-items: center; gap: 0.125rem; }
  .stat-n {
    font-family: var(--ink-font-display);
    font-size: 1.75rem; font-weight: 700;
    color: var(--ink-primary); line-height: 1;
  }
  .stat-l {
    font-family: var(--ink-font-mono);
    font-size: 0.625rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--ink-dim);
  }
  .stat-sep { width: 1px; height: 2rem; background: var(--ink-border); }

  /* ── Animation ── */
  .anim-section {
    background: #0a0604;
    border-bottom: 1px solid #ff7a1a33;
  }
  .anim-label {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.75rem 1.5rem;
    border-bottom: 1px solid #ff7a1a22;
  }
  .anim-tag {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.625rem; letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border: 1px solid #ff7a1a;
    color: #ff7a1a;
    flex-shrink: 0;
  }
  .anim-caption {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem; color: #b8520f;
    letter-spacing: 0.04em;
  }
  .anim-stage {
    width: 100%;
    height: min(56vw, 700px);
    min-height: 360px;
  }
  .anim-legend {
    padding: 0.5rem 1.5rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.6875rem;
    color: #b8520f;
    letter-spacing: 0.06em;
    border-top: 1px solid #ff7a1a22;
  }
  .legend-dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 1px;
    vertical-align: middle;
    margin-right: 4px;
  }
  .legend-dot.orange { background: #ffa04d; }
  .legend-dot.cyan   { background: #3de3ff; }
  .legend-dot.green  { background: #4dff9f; }

  /* ── Architecture strip ── */
  .arch-strip {
    background: var(--ink-surface);
    border-bottom: 1px solid var(--ink-border);
    padding: 2rem 1.5rem;
  }
  .arch-inner {
    max-width: var(--ink-page-width);
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    gap: 0;
    overflow-x: auto;
  }
  .arch-block {
    flex: 1; min-width: 160px; padding: 0 1.25rem;
  }
  .arch-block:first-child { padding-left: 0; }
  .arch-block-label {
    font-family: var(--ink-font-mono);
    font-size: 0.625rem; letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-primary);
    font-weight: 700;
    margin-bottom: 0.25rem;
  }
  .arch-block-n {
    font-family: var(--ink-font-display);
    font-size: 1rem; font-weight: 700;
    color: var(--ink-text);
    margin-bottom: 0.5rem;
  }
  .arch-block-desc {
    font-size: 0.8125rem; color: var(--ink-muted); line-height: 1.45;
  }
  .arch-arrow {
    font-family: var(--ink-font-mono);
    color: var(--ink-border);
    font-size: 1.25rem;
    padding-top: 0.25rem;
    flex-shrink: 0;
    align-self: flex-start;
    margin-top: 0.375rem;
  }

  /* ── Sections ── */
  .section { padding: 3.5rem 1.5rem; }
  .section.alt { background: var(--ink-surface); }
  .section-inner { max-width: var(--ink-page-width); margin: 0 auto; }
  .section-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 2rem; gap: 1rem;
  }
  .section-title {
    font-family: var(--ink-font-display);
    font-size: 1.75rem; font-weight: 700;
    color: var(--ink-text);
    letter-spacing: -0.02em; margin: 0 0 0.25rem;
  }
  .section-desc { font-size: 0.9375rem; color: var(--ink-muted); margin: 0; }
  .section-link {
    font-family: var(--ink-font-mono); font-size: 0.8125rem;
    color: var(--ink-primary); text-decoration: none; font-weight: 600;
    white-space: nowrap; margin-top: 0.25rem;
  }
  .section-link:hover { text-decoration: underline; }

  /* ── Plugins ── */
  .plugin-columns {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;
  }
  .plugin-col {
    display: flex; flex-direction: column; gap: 0.375rem;
  }
  .plugin-col-header {
    font-family: var(--ink-font-mono);
    font-size: 0.625rem; letter-spacing: 0.15em;
    text-transform: uppercase; font-weight: 700;
    margin-bottom: 0.375rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid currentColor;
  }
  .plugin-col-header.orange { color: #ffa04d; border-color: #ffa04d44; }
  .plugin-col-header.cyan   { color: var(--ink-secondary); border-color: color-mix(in srgb, var(--ink-secondary) 30%, transparent); }
  .plugin-col-header.green  { color: var(--ink-accent); border-color: color-mix(in srgb, var(--ink-accent) 30%, transparent); }

  .plugin-chip {
    font-family: var(--ink-font-mono);
    font-size: 0.8125rem; letter-spacing: 0.03em;
    padding: 0.375rem 0.625rem;
    border: 1px solid var(--ink-border);
    border-radius: calc(var(--ink-radius) - 2px);
    color: var(--ink-muted);
    transition: border-color 0.12s, color 0.12s;
  }
  .plugin-chip.orange:hover { border-color: #ffa04d; color: #ffa04d; }
  .plugin-chip.cyan:hover   { border-color: var(--ink-secondary); color: var(--ink-secondary); }
  .plugin-chip.green:hover  { border-color: var(--ink-accent); color: var(--ink-accent); }

  .plugin-note {
    margin-top: 1.5rem; font-size: 0.875rem; color: var(--ink-dim);
  }
  .plugin-note code {
    font-family: var(--ink-font-mono); font-size: 0.8125em;
    color: var(--ink-primary);
    background: color-mix(in srgb, var(--ink-primary) 10%, transparent);
    padding: 0.1em 0.35em; border-radius: 3px;
  }

  /* ── Ports ── */
  .ports-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .port-card {
    padding: 1rem 1.25rem;
    background: var(--ink-bg);
    border: 1px solid var(--ink-border);
    border-radius: var(--ink-radius);
