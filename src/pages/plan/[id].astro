---
import Base from '../../layouts/Base.astro'
import Header from '../../components/layout/Header.astro'
import Footer from '../../components/layout/Footer.astro'
import PlanDashboard from '../../components/PlanDashboard'
import { config } from '../../lib/config'

const { id } = Astro.params
const apiBase = config.workerUrl ?? ''
---

<Base
  title="Your 90-Day Growth Plan"
  description="Your personalized marketing roadmap — step-by-step actions tailored to your business."
>
  <Header />

  <main style="min-height: 80vh; padding: 3rem 1.5rem 5rem;">
    {id ? (
      <PlanDashboard
        client:load
        planId={id}
        apiBase={apiBase}
      />
    ) : (
      <div style="text-align: center; padding: 4rem 1rem; color: var(--ink-muted);">
        Invalid plan link.
      </div>
    )}
  </main>

  <Footer />
</Base>
