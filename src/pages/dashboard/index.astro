---
import Dashboard from '../../layouts/Dashboard.astro'
import { KPICard } from '../../components/charts/KPICard'
import { LineChart } from '../../components/charts/LineChart'
import { BarChart } from '../../components/charts/BarChart'
import { DataTable } from '../../components/charts/DataTable'
---

<Dashboard title="Overview" active="dashboard">
  <style>
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .chart-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    @media (max-width: 1100px) {
      .kpi-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 640px) {
      .kpi-grid { grid-template-columns: 1fr; }
      .chart-row { grid-template-columns: 1fr; }
    }
  </style>

  <div class="kpi-grid">
    <KPICard
      client:visible
      title="Organic Clicks"
      endpoint="/api/dashboard/overview"
      field="organic_clicks"
      icon="🖱️"
    />
    <KPICard
      client:visible
      title="Total Impressions"
      endpoint="/api/dashboard/overview"
      field="impressions"
      icon="👁️"
    />
    <KPICard
      client:visible
      title="Active Leads"
      endpoint="/api/dashboard/overview"
      field="active_leads"
      icon="◎"
    />
    <KPICard
      client:visible
      title="Ad Spend"
      endpoint="/api/dashboard/overview"
      field="ad_spend"
      format="currency"
      icon="💰"
    />
  </div>

  <div class="chart-row">
    <LineChart
      client:visible
      title="Clicks Over Time (28 days)"
      endpoint="/api/dashboard/clicks-trend"
      dataKey="clicks"
      xKey="date"
    />
    <BarChart
      client:visible
      title="Top Queries"
      endpoint="/api/dashboard/top-queries"
      dataKey="clicks"
      xKey="query"
      horizontal={true}
    />
  </div>

  <DataTable
    client:visible
    title="Top Landing Pages"
    endpoint="/api/dashboard/top-pages"
    limit={10}
    columns={[
      { key: 'page',        label: 'Page',        format: 'url',     width: '40%' },
      { key: 'clicks',      label: 'Clicks',      format: 'number',  align: 'right' },
      { key: 'impressions', label: 'Impressions', format: 'number',  align: 'right' },
      { key: 'ctr',         label: 'CTR',         format: 'percent', align: 'right' },
      { key: 'position',    label: 'Position',    align: 'right' },
    ]}
  />
</Dashboard>
