---
// Self-serve signup page. Posts to /auth/register, then redirects to /dashboard.
import { generateCssVars } from '../../lib/theme'

const cssVars = generateCssVars()
---

<html lang="en" dir="ltr" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style set:html={cssVars}></style>
    <title>Create Account</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: var(--ink-bg);
        color: var(--ink-text);
        font-family: system-ui, -apple-system, sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
      }

      .signup-card {
        background: var(--ink-surface);
        border: 1px solid var(--ink-border);
        border-radius: 12px;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 420px;
      }

      .signup-logo {
        text-align: center;
        font-size: 2.5rem;
        color: var(--ink-primary);
        line-height: 1;
        margin-bottom: 0.5rem;
      }

      .signup-heading {
        text-align: center;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--ink-text);
        margin-bottom: 0.5rem;
      }

      .signup-subtext {
        text-align: center;
        font-size: 0.82rem;
        color: var(--ink-muted);
        margin-bottom: 2rem;
      }

      .form-group {
        margin-bottom: 1rem;
      }

      .form-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--ink-muted);
        margin-bottom: 0.375rem;
      }

      .form-input {
        width: 100%;
        padding: 0.625rem 0.875rem;
        background: var(--ink-bg);
        border: 1px solid var(--ink-border);
        border-radius: 8px;
        color: var(--ink-text);
        font-size: 0.9rem;
        font-family: inherit;
        transition: border-color 0.15s;
        outline: none;
      }

      .form-input:focus {
        border-color: var(--ink-primary);
      }

      .form-input::placeholder {
        color: var(--ink-dim);
      }

      .submit-btn {
        width: 100%;
        padding: 0.75rem;
        background: var(--ink-primary);
        color: #0A0A10;
        border: none;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.15s;
        margin-top: 0.5rem;
        font-family: inherit;
      }

      .submit-btn:hover {
        opacity: 0.88;
      }

      .submit-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      .login-prompt {
        text-align: center;
        font-size: 0.82rem;
        color: var(--ink-muted);
        margin-top: 1.5rem;
      }

      .login-prompt a {
        color: var(--ink-primary);
        text-decoration: none;
        font-weight: 500;
      }

      .login-prompt a:hover {
        text-decoration: underline;
      }

      .error-msg {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #f87171;
        border-radius: 8px;
        padding: 0.625rem 0.875rem;
        font-size: 0.82rem;
        margin-bottom: 1rem;
        display: none;
      }

      .success-msg {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.3);
        color: #6ee7b7;
        border-radius: 8px;
        padding: 0.625rem 0.875rem;
        font-size: 0.82rem;
        margin-bottom: 1rem;
        display: none;
      }
    </style>
  </head>
  <body>
    <div class="signup-card">
      <div class="signup-logo">◎</div>
      <h1 class="signup-heading">Create your account</h1>
      <p class="signup-subtext">Get started in seconds.</p>

      <div id="error-msg" class="error-msg"></div>
      <div id="success-msg" class="success-msg"></div>

      <form id="signup-form" novalidate>
        <div class="form-group">
          <label class="form-label" for="name">Your name</label>
          <input
            id="name"
            name="name"
            type="text"
            class="form-input"
            placeholder="Jane Smith"
            autocomplete="name"
            required
          />
        </div>

        <div class="form-group">
          <label class="form-label" for="business">Business name</label>
          <input
            id="business"
            name="business"
            type="text"
            class="form-input"
            placeholder="Acme Corp"
            required
          />
        </div>

        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            class="form-input"
            placeholder="you@example.com"
            autocomplete="email"
            required
          />
        </div>

        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input
            id="password"
            name="password"
            type="password"
            class="form-input"
            placeholder="Min. 8 characters"
            autocomplete="new-password"
            required
            minlength="8"
          />
        </div>

        <button type="submit" id="submit-btn" class="submit-btn">Create account</button>
      </form>

      <p class="login-prompt">
        Already have an account?
        <a href="/dashboard/login">Log in</a>
      </p>
    </div>

    <script is:inline>
      var apiUrl = localStorage.getItem('inkwell_api_url') || window.location.origin
      var signupForm = document.getElementById('signup-form')
      var errorMsg = document.getElementById('error-msg')
      var successMsg = document.getElementById('success-msg')
      var submitBtn = document.getElementById('submit-btn')

      function showError(msg) { errorMsg.textContent = msg; errorMsg.style.display = 'block'; successMsg.style.display = 'none' }
      function showSuccess(msg) { successMsg.textContent = msg; successMsg.style.display = 'block'; errorMsg.style.display = 'none' }
      function hideMessages() { errorMsg.style.display = 'none'; successMsg.style.display = 'none' }

      signupForm.addEventListener('submit', async function(e) {
        e.preventDefault()
        hideMessages()

        var fullName = document.getElementById('name').value.trim()
        var business = document.getElementById('business').value.trim()
        var email = document.getElementById('email').value.trim()
        var password = document.getElementById('password').value

        if (!fullName || !business || !email || !password) { showError('Please fill in all fields.'); return }
        if (password.length < 8) { showError('Password must be at least 8 characters.'); return }

        var customerSlug = business.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '')
        submitBtn.disabled = true
        submitBtn.textContent = 'Creating account…'

        try {
          var resp = await fetch(apiUrl + '/api/auth/password-register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ customerSlug: customerSlug, email: email, password: password, fullName: fullName }),
          })
          var data = await resp.json()
          if (!resp.ok) {
            var msg = data.error === 'email_already_registered' ? 'An account with this email already exists.' : data.error || 'Could not create account.'
            showError(msg)
            submitBtn.disabled = false
            submitBtn.textContent = 'Create account'
            return
          }

          if (data.session) {
            localStorage.setItem('inkwell_tenant_slug', data.session.customerSlug)
            localStorage.setItem('inkwell_auth_token', data.sessionToken)
            localStorage.setItem('inkwell_user_role', data.session.role || 'viewer')
            localStorage.setItem('inkwell_api_url', apiUrl)
          }
          showSuccess('Account created! Setting up your workspace…')
          setTimeout(function() { window.location.href = '/dashboard/onboarding' }, 800)
        } catch (_) {
          showError('Could not reach server.')
          submitBtn.disabled = false
          submitBtn.textContent = 'Create account'
        }
      })
    </script>
  </body>
</html>
