---
// Self-serve signup page. Posts to /auth/register, then redirects to /dashboard.
import { generateCssVars } from '../../lib/theme'

const cssVars = generateCssVars()
---

<html lang="en" dir="ltr" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style set:html={cssVars}></style>
    <title>Create Account — Mumega</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background: var(--ink-bg);
        color: var(--ink-text);
        font-family: system-ui, -apple-system, sans-serif;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
      }

      .signup-card {
        background: var(--ink-surface);
        border: 1px solid var(--ink-border);
        border-radius: 12px;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 420px;
      }

      .signup-logo {
        text-align: center;
        font-size: 2.5rem;
        color: var(--ink-primary);
        line-height: 1;
        margin-bottom: 0.5rem;
      }

      .signup-heading {
        text-align: center;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--ink-text);
        margin-bottom: 0.5rem;
      }

      .signup-subtext {
        text-align: center;
        font-size: 0.82rem;
        color: var(--ink-muted);
        margin-bottom: 2rem;
      }

      .form-group {
        margin-bottom: 1rem;
      }

      .form-label {
        display: block;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--ink-muted);
        margin-bottom: 0.375rem;
      }

      .form-input {
        width: 100%;
        padding: 0.625rem 0.875rem;
        background: var(--ink-bg);
        border: 1px solid var(--ink-border);
        border-radius: 8px;
        color: var(--ink-text);
        font-size: 0.9rem;
        font-family: inherit;
        transition: border-color 0.15s;
        outline: none;
      }

      .form-input:focus {
        border-color: var(--ink-primary);
      }

      .form-input::placeholder {
        color: var(--ink-dim);
      }

      .submit-btn {
        width: 100%;
        padding: 0.75rem;
        background: var(--ink-primary);
        color: #0A0A10;
        border: none;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.15s;
        margin-top: 0.5rem;
        font-family: inherit;
      }

      .submit-btn:hover {
        opacity: 0.88;
      }

      .submit-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
      }

      .login-prompt {
        text-align: center;
        font-size: 0.82rem;
        color: var(--ink-muted);
        margin-top: 1.5rem;
      }

      .login-prompt a {
        color: var(--ink-primary);
        text-decoration: none;
        font-weight: 500;
      }

      .login-prompt a:hover {
        text-decoration: underline;
      }

      .error-msg {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.3);
        color: #f87171;
        border-radius: 8px;
        padding: 0.625rem 0.875rem;
        font-size: 0.82rem;
        margin-bottom: 1rem;
        display: none;
      }

      .success-msg {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.3);
        color: #6ee7b7;
        border-radius: 8px;
        padding: 0.625rem 0.875rem;
        font-size: 0.82rem;
        margin-bottom: 1rem;
        display: none;
      }
    </style>
  </head>
  <body>
    <div class="signup-card">
      <div class="signup-logo">◎</div>
      <h1 class="signup-heading">Create your account</h1>
      <p class="signup-subtext">Your AI business operator is ready in seconds.</p>

      <div id="error-msg" class="error-msg"></div>
      <div id="success-msg" class="success-msg"></div>

      <form id="signup-form" novalidate>
        <div class="form-group">
          <label class="form-label" for="name">Your name</label>
          <input
            id="name"
            name="name"
            type="text"
            class="form-input"
            placeholder="Jane Smith"
            autocomplete="name"
            required
          />
        </div>

        <div class="form-group">
          <label class="form-label" for="business">Business name</label>
          <input
            id="business"
            name="business"
            type="text"
            class="form-input"
            placeholder="Acme Corp"
            required
          />
        </div>

        <div class="form-group">
          <label class="form-label" for="email">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            class="form-input"
            placeholder="you@example.com"
            autocomplete="email"
            required
          />
        </div>

        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input
            id="password"
            name="password"
            type="password"
            class="form-input"
            placeholder="••••••••"
            autocomplete="new-password"
            required
            minlength="8"
          />
        </div>

        <button type="submit" id="submit-btn" class="submit-btn">Create Account</button>
      </form>

      <p class="login-prompt">
        Already have an account?
        <a href="/dashboard/login">Log in</a>
      </p>
    </div>

    <script is:inline>
      const form = document.getElementById('signup-form')
      const errorMsg = document.getElementById('error-msg')
      const successMsg = document.getElementById('success-msg')
      const submitBtn = document.getElementById('submit-btn')

      form.addEventListener('submit', async (e) => {
        e.preventDefault()
        errorMsg.style.display = 'none'
        successMsg.style.display = 'none'

        const name = form.name.value.trim()
        const business = form.business.value.trim()
        const email = form.email.value.trim()
        const password = form.password.value

        if (!name || !business || !email || !password) {
          errorMsg.textContent = 'Please fill in all fields.'
          errorMsg.style.display = 'block'
          return
        }

        if (password.length < 8) {
          errorMsg.textContent = 'Password must be at least 8 characters.'
          errorMsg.style.display = 'block'
          return
        }

        submitBtn.disabled = true
        submitBtn.textContent = 'Creating account…'

        try {
          const resp = await fetch('https://api.mumega.com/auth/register', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password, name: business }),
          })

          if (!resp.ok) {
            const err = await resp.json().catch(() => ({}))
            errorMsg.textContent = err.detail || 'Could not create account. Try a different name.'
            errorMsg.style.display = 'block'
            submitBtn.disabled = false
            submitBtn.textContent = 'Create Account'
            return
          }

          const data = await resp.json()
          const user = data.user

          // Store tenant info
          if (user?.tenant) localStorage.setItem('mumega_tenant_slug', user.tenant)

          // Fetch bus token
          try {
            const tenantResp = await fetch(
              `https://api.mumega.com/auth/tenant?email=${encodeURIComponent(email)}`
            )
            if (tenantResp.ok) {
              const tenantData = await tenantResp.json()
              if (tenantData.bus_token) {
                localStorage.setItem('mumega_auth_token', tenantData.bus_token)
              }
            }
          } catch (_) {}

          successMsg.textContent = 'Account created! Redirecting to your dashboard…'
          successMsg.style.display = 'block'

          setTimeout(() => {
            window.location.href = '/dashboard'
          }, 1200)
        } catch (err) {
          errorMsg.textContent = 'Something went wrong. Please try again.'
          errorMsg.style.display = 'block'
          submitBtn.disabled = false
          submitBtn.textContent = 'Create Account'
        }
      })
    </script>
  </body>
</html>
