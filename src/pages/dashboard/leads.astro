---
import Dashboard from '../../layouts/Dashboard.astro'
import { KPICard } from '../../components/charts/KPICard'
import { BarChart } from '../../components/charts/BarChart'
import { DataTable } from '../../components/charts/DataTable'
---

<Dashboard title="Leads" active="leads">
  <style>
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .section-gap {
      margin-bottom: 1.5rem;
    }
    @media (max-width: 1100px) {
      .kpi-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 640px) {
      .kpi-grid { grid-template-columns: 1fr; }
    }
  </style>

  <div class="kpi-grid">
    <KPICard
      client:visible
      title="Total Leads"
      endpoint="/api/dashboard/leads"
      field="total_leads"
      icon="◎"
    />
    <KPICard
      client:visible
      title="This Week"
      endpoint="/api/dashboard/leads"
      field="this_week"
      icon="📅"
    />
    <KPICard
      client:visible
      title="Avg Response Time"
      endpoint="/api/dashboard/leads"
      field="avg_response_hours"
      icon="⏱️"
    />
    <KPICard
      client:visible
      title="Conversion Rate"
      endpoint="/api/dashboard/leads"
      field="conversion_rate"
      format="percent"
      icon="◉"
    />
  </div>

  <div class="section-gap">
    <BarChart
      client:visible
      title="Leads by Source"
      endpoint="/api/dashboard/leads-by-source"
      dataKey="leads"
      xKey="source"
      color="var(--ink-secondary)"
    />
  </div>

  <DataTable
    client:visible
    title="Recent Leads"
    endpoint="/api/dashboard/leads-recent"
    limit={20}
    columns={[
      { key: 'name',        label: 'Name',        width: '20%' },
      { key: 'source',      label: 'Source',      width: '15%' },
      { key: 'destination', label: 'Destination', width: '20%' },
      { key: 'date',        label: 'Date',        width: '15%' },
      { key: 'status',      label: 'Status',      format: 'status', align: 'center' },
    ]}
  />
</Dashboard>
