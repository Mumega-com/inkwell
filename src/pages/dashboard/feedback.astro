---
import Dashboard from '../../layouts/Dashboard.astro'
import { NpsWidget } from '../../../plugins/feedback/components/NpsWidget'
import { FeatureVoteBoard } from '../../../plugins/feedback/components/FeatureVoteBoard'
import { KPICard } from '../../components/charts/KPICard'
---

<Dashboard title="Feedback" active="feedback">
  <style>
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .section-gap {
      margin-bottom: 1.5rem;
    }
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    @media (max-width: 900px) {
      .kpi-grid { grid-template-columns: 1fr; }
      .two-col { grid-template-columns: 1fr; }
    }
  </style>

  <div class="kpi-grid">
    <KPICard
      client:visible
      title="NPS Score"
      endpoint="/api/feedback/insights"
      field="nps_score"
      icon="◇"
    />
    <KPICard
      client:visible
      title="Responses"
      endpoint="/api/feedback/insights"
      field="total_responses"
      icon="◎"
    />
    <KPICard
      client:visible
      title="Feature Requests"
      endpoint="/api/feedback/insights"
      field="total_features"
      icon="☐"
    />
  </div>

  <div class="two-col">
    <div>
      <h3 style="color: var(--ink-text); font-size: 0.95rem; font-weight: 600; margin: 0 0 1rem;">Quick NPS Survey</h3>
      <NpsWidget client:load surveyId="dashboard-nps" question="How likely are you to recommend us to a colleague?" />
    </div>

    <div>
      <FeatureVoteBoard client:load showSubmitForm={true} />
    </div>
  </div>
</Dashboard>
