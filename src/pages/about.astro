---
import Base from '../layouts/Base.astro'
import Header from '../components/layout/Header.astro'
import Footer from '../components/layout/Footer.astro'
import JsonLd from '../components/seo/JsonLd.astro'
import NotConfigured from '../components/NotConfigured.astro'
import { getEntry, render } from 'astro:content'

// Graceful-fail when fork hasn't provided content/<lang>/pages/about.md.
// Renders the NotConfigured fallback at HTTP 200 instead of throwing at build
// or rendering empty HTML. See Mumega-com/inkwell #49 (P-007).
const page = await getEntry('pages', 'about')
const rendered = page ? await render(page) : null

const jsonLdContent = page ? {
  slug: '/about/',
  title: page.data.title,
  type: 'page' as const,
  description: page.data.description,
} : null
---

<Base
  title={page?.data.title ?? 'About — page not configured'}
  description={page?.data.description}
>
  {jsonLdContent && <JsonLd content={jsonLdContent} />}
  <Header />

  {page && rendered ? (
    <main class="page">
      <article class="page-inner ink-prose">
        <h1>{page.data.title}</h1>
        <rendered.Content />
      </article>
    </main>
  ) : (
    <NotConfigured collection="pages" slug="about" />
  )}

  <Footer />
</Base>

<style>
  main {
    padding-top: 3.5rem;
  }

  .page {
    max-width: var(--ink-page-width);
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .page-inner {
    max-width: var(--ink-content-width);
    margin: 0 auto;
  }
</style>
