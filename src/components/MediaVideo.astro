---
import type { MediaAsset } from '../../kernel/types'

interface Props {
  id: string
  asset?: MediaAsset
  poster?: string
  caption?: string
  class?: string
}

const { id, asset, poster, caption, class: className } = Astro.props

const videoSrc = asset?.variants?.hls || asset?.r2Key || ''
const posterUrl = poster || asset?.variants?.thumbnail || ''
const chapters = asset?.chapters || []
const hasTranscript = Boolean(asset?.transcript)

function formatTime(seconds: number): string {
  const mins = Math.floor(seconds / 60)
  const secs = Math.floor(seconds % 60)
  return `${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')}`
}
---

<figure
  class:list={['media-video', className]}
  data-media-id={id}
>
  <div class="media-video__wrapper">
    {asset ? (
      <video
        controls
        preload="metadata"
        poster={posterUrl || undefined}
        class="media-video__player"
      >
        <source src={videoSrc} type="video/mp4" />
        {hasTranscript && (
          <track
            kind="captions"
            src={`/api/media/${id}/captions.vtt`}
            default
          />
        )}
      </video>
    ) : (
      <video
        controls
        preload="metadata"
        class="media-video__player"
        data-media-id={id}
      />
    )}
  </div>

  {chapters.length > 0 && (
    <div class="media-video__chapters">
      {chapters.map((ch) => (
        <button
          class="media-video__chapter"
          data-time={ch.time}
          type="button"
        >
          <span class="media-video__chapter-time">{formatTime(ch.time)}</span>
          <span>{ch.title}</span>
        </button>
      ))}
    </div>
  )}

  {caption && (
    <figcaption class="media-video__caption">
      {caption}
    </figcaption>
  )}
</figure>

<style>
  .media-video {
    margin: 2rem 0;
  }

  .media-video__wrapper {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--ink-surface);
    border-radius: var(--ink-radius);
    overflow: hidden;
  }

  .media-video__player {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .media-video__chapters {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-top: 0.5rem;
  }

  .media-video__chapter {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.5rem;
    background: none;
    border: none;
    border-radius: var(--ink-radius);
    cursor: pointer;
    font-size: 0.875rem;
    line-height: 1.4;
    color: var(--ink-text);
    text-align: left;
    transition: background 0.15s ease;
  }

  .media-video__chapter:hover {
    background: var(--ink-surface);
  }

  .media-video__chapter-time {
    font-family: var(--ink-font-mono);
    font-size: 0.8125rem;
    color: var(--ink-muted);
    min-width: 3.5rem;
    flex-shrink: 0;
  }

  .media-video__caption {
    margin-top: 0.625rem;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--ink-muted);
    text-align: center;
  }
</style>
